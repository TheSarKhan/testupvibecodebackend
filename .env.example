# Server
SERVER_PORT=8082

# Database
DB_URL=jdbc:postgresql://localhost:5433/testup_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# SendPulse
SENDPULSE_CLIENT_ID=your_sendpulse_client_id
SENDPULSE_CLIENT_SECRET=your_sendpulse_client_secret
SENDPULSE_FROM_EMAIL=your_email@gmail.com
SENDPULSE_FROM_NAME=testup.az

# JWT
JWT_SECRET=your_base64_encoded_secret
JWT_ACCESS_TOKEN_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=2592000000

# Kapital Bank E-commerce
KAPITALBANK_USERNAME=your_kb_username
KAPITALBANK_PASSWORD=your_kb_password
KAPITALBANK_PRODUCTION=false
